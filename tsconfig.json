{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "noEmit": true
    },
    "include": [
        "packages/*/src/**/*.ts",
        "packages/*/bin/**/*.ts",
        "scripts/**/*.ts",
        "benchmarks/**/*.ts"
    ],
    "exclude": [
        "**/dist/**",
        "**/node_modules/**",
        "benchmarks/generated/**",
        "benchmarks/generated-compare.bench.ts"
    ]
}
